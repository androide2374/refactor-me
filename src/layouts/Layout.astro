---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'OnFit Focus | Fase de adaptacion 1-4',
	description = 'Plan visual de entrenamiento para construir habito, mejorar postura y entrenar con maquinas guiadas sin complicaciones.'
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#165d48" />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>
