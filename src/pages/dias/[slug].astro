---
import { ArrowLeft, ArrowRight, Clock3, Dumbbell, Gauge, Layers3, Target } from 'lucide-react';

import AppHeader from '../../components/AppHeader.astro';
import AuthGuard from '../../components/AuthGuard';
import WeightLogger from '../../components/WeightLogger';
import { exercises, getExercisesForDay, trainingDays } from '../../data/training-plan';
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
    return trainingDays.map((dayPlan) => ({
        params: { slug: dayPlan.slug },
        props: { dayPlan }
    }));
}

const { dayPlan } = Astro.props;

const dayIndex = trainingDays.findIndex((item) => item.id === dayPlan.id);
const nextDay = trainingDays[(dayIndex + 1) % trainingDays.length];
const previousDay = trainingDays[(dayIndex - 1 + trainingDays.length) % trainingDays.length];

const dayExercises = getExercisesForDay(dayPlan.exerciseOrder, exercises);

const totalSets = dayExercises.reduce((accumulator, exercise) => accumulator + exercise.sets, 0);
---

<Layout title={`OnFit | ${dayPlan.day} · ${dayPlan.title}`} description={`${dayPlan.day}: ${dayPlan.title}. ${dayPlan.focus}`}>
    <AuthGuard client:load>
    <main class="mx-auto flex min-h-screen max-w-7xl flex-col gap-8 px-4 py-6 sm:px-6 lg:px-8 lg:py-8">
        <AppHeader />

        <section class="relative overflow-hidden rounded-[2rem] border border-border/70 bg-card/85 p-6 shadow-[0_24px_80px_rgba(18,38,31,0.12)] sm:p-8">
            <div class="absolute inset-x-0 top-0 h-1.5" style={`background:${dayPlan.colorHex}`}></div>

            <div class="flex flex-wrap items-center gap-2">
                <span class="inline-flex items-center gap-2 rounded-full border border-border bg-background/80 px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em] text-muted-foreground">
                    <Clock3 className="h-3.5 w-3.5" />
                    {dayPlan.day} · ~60 min
                </span>
                <span class="inline-flex items-center gap-2 rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em]" style={`background:${dayPlan.colorHex}22;color:${dayPlan.colorHex}`}>
                    <Target className="h-3.5 w-3.5" />
                    {dayPlan.colorName}
                </span>
            </div>

            <h1 class="mt-4 text-4xl font-semibold tracking-[-0.04em] text-foreground sm:text-5xl">{dayPlan.title}</h1>
            <p class="mt-3 max-w-3xl text-base leading-7 text-muted-foreground">{dayPlan.focus}</p>
            <p class="mt-3 max-w-3xl text-sm leading-6 text-muted-foreground">{dayPlan.note}</p>

            <div class="mt-6 grid gap-3 sm:grid-cols-3">
                <article class="rounded-[1.2rem] border border-border/70 bg-background/75 p-4">
                    <p class="text-sm text-muted-foreground">Ejercicios</p>
                    <p class="mt-1 text-2xl font-semibold text-foreground">{dayExercises.length}</p>
                </article>
                <article class="rounded-[1.2rem] border border-border/70 bg-background/75 p-4">
                    <p class="text-sm text-muted-foreground">Series totales</p>
                    <p class="mt-1 text-2xl font-semibold text-foreground">{totalSets}</p>
                </article>
                <article class="rounded-[1.2rem] border border-border/70 bg-background/75 p-4">
                    <p class="text-sm text-muted-foreground">Siguiente dia</p>
                    <p class="mt-1 text-2xl font-semibold text-foreground">{nextDay.title}</p>
                </article>
            </div>
        </section>

        <section class="rounded-[2rem] border border-border/70 bg-card/80 p-5 shadow-[0_10px_30px_rgba(18,38,31,0.06)] sm:p-6">
            <div class="flex items-center gap-3 mb-4">
                <span class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-accent/12 text-accent-foreground">
                    <Clock3 className="h-5 w-5" />
                </span>
                <div>
                    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-accent-foreground">Calentamiento y cardio</p>
                    <h2 class="mt-1 text-2xl font-semibold tracking-[-0.03em] text-foreground">Preparacion y salida</h2>
                </div>
            </div>

            <div class="grid gap-4 md:grid-cols-2">
                <div class="rounded-[1.2rem] border border-border/70 bg-background/75 p-4">
                    <p class="text-xs font-semibold uppercase tracking-[0.14em] text-primary">Calentamiento especifico</p>
                    <ul class="mt-3 grid gap-2">
                        {dayPlan.warmup.map((step: string) => (
                            <li class="flex items-start gap-2 text-sm leading-6 text-foreground/86">
                                <span class="mt-1.5 block h-1.5 w-1.5 shrink-0 rounded-full" style={`background:${dayPlan.colorHex}`}></span>
                                {step}
                            </li>
                        ))}
                    </ul>
                </div>
                <div class="rounded-[1.2rem] border border-border/70 bg-background/75 p-4 flex flex-col gap-4">
                    <div>
                        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-primary">Despues de los ejercicios</p>
                        <p class="mt-3 text-sm leading-6 text-foreground/86">
                            <strong>Cardio de salida:</strong> 15 min de bici, cinta o eliptica a ritmo suave (RPE 3-4) para bajar pulsaciones, hidratarte y cerrar la sesion sin corte brusco.
                        </p>
                    </div>
                    <div class="rounded-[1rem] border border-border/70 bg-card/60 p-3 text-xs leading-5 text-muted-foreground">
                        Mantene ritmo conversacional en todo el cardio. No conviertas la salida en HIIT. Aprovecha para hidratarte en los ultimos minutos.
                    </div>
                </div>
            </div>
        </section>

        {
            dayExercises.length === 0 ? (
                <section class="rounded-[2rem] border border-border/70 bg-card/80 p-8 text-center shadow-[0_10px_30px_rgba(18,38,31,0.06)]">
                    <div class="mx-auto max-w-lg space-y-4">
                        <span class="inline-flex h-16 w-16 items-center justify-center rounded-2xl bg-primary/10 text-primary">
                            <Dumbbell className="h-8 w-8" />
                        </span>
                        <h2 class="text-2xl font-semibold text-foreground">Ejercicios pendientes</h2>
                        <p class="text-sm leading-6 text-muted-foreground">
                            Los ejercicios para {dayPlan.day} todavia no fueron cargados. Vuelve pronto para ver los movimientos especificos de este dia.
                        </p>
                    </div>
                </section>
            ) : (
                <section class="space-y-4">
                    <div>
                        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-primary">Ejercicios del dia</p>
                        <h2 class="mt-1 text-3xl font-semibold tracking-[-0.04em] text-foreground">{dayExercises.length} ejercicios para {dayPlan.day}</h2>
                    </div>
                    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
                        {
                            dayExercises.map((exercise) => (
                                <article class="rounded-[1.6rem] border border-border/70 bg-card/80 p-4 shadow-[0_10px_30px_rgba(18,38,31,0.06)]">
                                    <img
                                        src={exercise.imageUrl}
                                        alt={exercise.nameEs}
                                        loading="lazy"
                                        onerror={`if (this.src !== '${exercise.imageFallbackUrl}') this.src='${exercise.imageFallbackUrl}'`}
                                        class="h-44 w-full rounded-[1rem] object-cover"
                                    />
                                    <div class="mt-3 flex items-start justify-between gap-3">
                                        <div>
                                            <h3 class="text-lg font-semibold text-foreground">{exercise.nameEs}</h3>
                                            <p class="text-sm text-muted-foreground">{exercise.muscleGroup}</p>
                                        </div>
                                        <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-primary/10 text-primary">
                                            <Dumbbell className="h-4 w-4" />
                                        </span>
                                    </div>
                                    <div class="mt-3 flex flex-wrap gap-2 text-xs font-medium text-foreground/80">
                                        <span class="rounded-full bg-secondary px-3 py-1">{exercise.sets} series</span>
                                        <span class="rounded-full bg-secondary px-3 py-1">{exercise.reps} reps</span>
                                        <span class="rounded-full bg-secondary px-3 py-1">{exercise.restSeconds}s desc</span>
                                    </div>
                                    <p class="mt-3 text-sm leading-6 text-muted-foreground">{exercise.description}</p>

                                    <details class="mt-4 rounded-[1rem] border border-border/70 bg-background/70 p-3">
                                        <summary class="inline-flex cursor-pointer list-none items-center gap-2 rounded-full border border-border bg-card px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.12em] text-foreground transition hover:border-primary/35">
                                            <Gauge className="h-3.5 w-3.5" />
                                            Tecnica y errores
                                        </summary>
                                        <div class="mt-3 space-y-3">
                                            <div>
                                                <p class="text-xs font-semibold uppercase tracking-[0.12em] text-primary">Como se hace</p>
                                                <ul class="mt-2 grid gap-1 text-xs text-muted-foreground">
                                                    {exercise.cues.map((cue) => (<li>· {cue}</li>))}
                                                </ul>
                                            </div>
                                            <div>
                                                <p class="text-xs font-semibold uppercase tracking-[0.12em] text-accent-foreground">Errores comunes</p>
                                                <ul class="mt-2 grid gap-1 text-xs text-muted-foreground">
                                                    {exercise.commonMistakes.map((mistake) => (<li>· {mistake}</li>))}
                                                </ul>
                                            </div>
                                        </div>
                                    </details>

                                    <a
                                        href={exercise.videoUrl}
                                        target="_blank"
                                        rel="noreferrer"
                                        class="mt-4 inline-flex w-full items-center justify-center gap-2 rounded-full bg-primary px-4 py-2.5 text-sm font-semibold text-primary-foreground transition hover:bg-primary/90"
                                    >
                                        Ver video en YouTube
                                    </a>

                                    <WeightLogger
                                        client:load
                                        exerciseName={exercise.name}
                                        exerciseNameEs={exercise.nameEs}
                                        prescribedSets={exercise.sets}
                                        prescribedReps={exercise.reps}
                                    />
                                </article>
                            ))
                        }
                    </div>
                </section>
            )
        }

        <section class="grid gap-3 sm:grid-cols-3">
            <a href="/" class="inline-flex items-center justify-center gap-2 rounded-full border border-border bg-background px-4 py-2.5 text-sm font-semibold text-foreground transition hover:border-primary/30">
                <ArrowLeft className="h-4 w-4" />
                Inicio
            </a>
            <a href={`/dias/${previousDay.slug}`} class="inline-flex items-center justify-center gap-2 rounded-full border border-border bg-background px-4 py-2.5 text-sm font-semibold text-foreground transition hover:border-primary/30">
                <Layers3 className="h-4 w-4" />
                {previousDay.day}: {previousDay.title}
            </a>
            <a href={`/dias/${nextDay.slug}`} class="inline-flex items-center justify-center gap-2 rounded-full bg-primary px-4 py-2.5 text-sm font-semibold text-primary-foreground transition hover:bg-primary/90">
                {nextDay.day}: {nextDay.title}
                <ArrowRight className="h-4 w-4" />
            </a>
        </section>
    </main>
    </AuthGuard>
</Layout>
