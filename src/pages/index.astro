---
import {
    Activity,
    Brain,
    Droplets,
    Footprints,
    Gauge,
    HeartPulse,
    MapPinned,
    MoonStar,
    RefreshCw,
    ShieldAlert,
    Target,
    UtensilsCrossed
} from 'lucide-react';
import AppHeader from '../components/AppHeader.astro';
import AuthGuard from '../components/AuthGuard';
import ExerciseTabs from '../components/ExerciseTabs';
import GymIllustration from '../components/GymIllustration.astro';
import TrainingDaysGrid from '../components/TrainingDaysGrid';
import SessionCharts from '../components/charts/SessionCharts';
import {
    athleteProfile,
    bmiReference,
    exercises,
    habitGuides
} from '../data/training-plan';
import Layout from '../layouts/Layout.astro';

const profileStats = [
    {
        label: 'Frecuencia',
        value: `${athleteProfile.trainingDays} dias en rotacion`,
        detail: 'Sin dias fijos. Si faltas, retomas donde quedaste.',
        icon: RefreshCw
    },
    {
        label: 'Duracion',
        value: `~${athleteProfile.sessionMinutes} min`,
        detail: 'Ejercicios directos, sin bloques de relleno.',
        icon: Activity
    },
    {
        label: 'Entorno',
        value: athleteProfile.gym,
        detail: 'Ejercicios en maquinas guiadas y poleas.',
        icon: MapPinned
    },
    {
        label: 'Referencia corporal',
        value: `IMC ${bmiReference}`,
        detail: 'Se prioriza tecnica, postura y continuidad.',
        icon: Gauge
    }
];

const quickSignals = [
    {
        title: 'Semaglutida',
        text: 'Hidratate antes de cada sesion. Apunta a 500-700 ml antes de entrenar y no esperes a tener sed.',
        icon: Droplets
    },
    {
        title: 'Presion alta previa',
        text: 'Si aparecen mareos, palpitaciones o dolor de cabeza pulsante, se corta la sesion y se consulta.',
        icon: ShieldAlert
    },
    {
        title: 'Trabajo mental alto',
        text: 'La meta no es exprimirte. La meta es cumplir 4 sesiones por rotacion con tecnica limpia.',
        icon: Brain
    }
];

const habitIcons = {
    'Hidratacion reforzada': Droplets,
    'Pre-entreno liviano': UtensilsCrossed,
    'Sueno util': MoonStar,
    'Calzado estable': Footprints
};
---

<Layout>
    <AuthGuard client:load>
    <main class="mx-auto flex min-h-screen max-w-7xl flex-col gap-12 px-4 py-6 sm:px-6 lg:px-8 lg:py-8">
        <AppHeader />

        <section class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr] lg:items-stretch">
            <div class="relative overflow-hidden rounded-[2rem] border border-border/70 bg-card/85 p-6 shadow-[0_24px_80px_rgba(18,38,31,0.14)] backdrop-blur xl:p-8">
                <div class="absolute inset-x-0 top-0 h-32 bg-[radial-gradient(circle_at_top,rgba(240,139,75,0.22),transparent_68%)]"></div>
                <div class="relative flex h-full flex-col justify-between gap-8">
                    <div class="space-y-5">
                        <div class="flex flex-wrap gap-2">
                            <span class="inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-primary">
                                <Target className="h-3.5 w-3.5" />
                                Rotacion de 4 dias
                            </span>
                            <span class="inline-flex items-center gap-2 rounded-full border border-accent/20 bg-accent/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-accent-foreground">
                                <HeartPulse className="h-3.5 w-3.5" />
                                Habito antes que intensidad
                            </span>
                        </div>
                        <div class="space-y-4">
                            <p class="max-w-fit rounded-full border border-border/70 bg-background/70 px-4 py-1 text-sm font-medium text-muted-foreground">
                                Plan visual con 4 dias en rotacion · sin calendario fijo
                            </p>
                            <h1 class="max-w-3xl text-4xl font-semibold leading-tight tracking-[-0.04em] text-foreground sm:text-5xl lg:text-6xl">
                                Entrena con maquinas, gira entre 4 dias y reduci friccion en cada sesion.
                            </h1>
                            <p class="max-w-2xl text-base leading-7 text-muted-foreground sm:text-lg">
                                Programa inicial para {athleteProfile.age} anos, {athleteProfile.weightKg} kg. Division: piernas delante + hombros, pecho + triceps, piernas atras + hombros, espalda + biceps. Si faltas un dia, retomas donde estabas.
                            </p>
                        </div>
                        <div class="flex flex-wrap gap-3">
                            <a href="#dias" class="inline-flex items-center justify-center rounded-full bg-primary px-5 py-3 text-sm font-semibold text-primary-foreground transition hover:translate-y-[-1px] hover:bg-primary/90">
                                Ver los 4 dias
                            </a>
                            <a href="#graficas" class="inline-flex items-center justify-center rounded-full border border-border bg-background/80 px-5 py-3 text-sm font-semibold text-foreground transition hover:border-primary/30 hover:bg-background">
                                Entender el plan
                            </a>
                        </div>
                    </div>
                    <div class="grid gap-3 sm:grid-cols-2">
                        <div class="rounded-[1.5rem] border border-border/70 bg-background/75 p-4">
                            <p class="text-sm text-muted-foreground">Horario preferido</p>
                            <p class="mt-2 text-2xl font-semibold text-foreground">08:30 am</p>
                            <p class="mt-2 text-sm text-muted-foreground">Ventana con mejor energia y menos ruido mental.</p>
                        </div>
                        <div class="rounded-[1.5rem] border border-border/70 bg-background/75 p-4">
                            <p class="text-sm text-muted-foreground">Meta principal</p>
                            <p class="mt-2 text-2xl font-semibold text-foreground">Bajar peso + postura</p>
                            <p class="mt-2 text-sm text-muted-foreground">Se consolida habito antes de buscar intensidad alta.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="relative overflow-hidden rounded-[2rem] border border-border/70 bg-[#15251e] p-6 text-white shadow-[0_24px_80px_rgba(18,38,31,0.14)] xl:p-8">
                <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_20%,rgba(240,139,75,0.35),transparent_30%),radial-gradient(circle_at_80%_10%,rgba(96,214,169,0.26),transparent_22%)]"></div>
                <div class="relative flex h-full flex-col justify-between gap-6">
                    <div class="space-y-4">
                        <p class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/8 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-white/80">
                            <Activity className="h-3.5 w-3.5" />
                            Como funciona
                        </p>
                        <h2 class="max-w-md text-2xl font-semibold tracking-[-0.03em] text-white sm:text-3xl">
                            Sin dias fijos. Sin calendario. Solo rotacion.
                        </h2>
                        <p class="max-w-md text-sm leading-6 text-white/72">
                            Vas al gimnasio y haces el dia que te toca en la rotacion. Si faltas un dia, no pasa nada: el proximo dia de gym haces el ejercicio que quedaba pendiente y seguis girando.
                        </p>
                    </div>
                    <div class="rounded-[1.75rem] border border-white/10 bg-white/6 p-3 backdrop-blur">
                        <GymIllustration />
                    </div>
                </div>
            </div>
        </section>

        <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            {
                profileStats.map((stat) => {
                    const Icon = stat.icon;

                    return (
                        <article class="rounded-[1.5rem] border border-border/70 bg-card/80 p-5 shadow-[0_10px_30px_rgba(18,38,31,0.06)]">
                            <div class="flex items-start justify-between gap-4">
                                <div>
                                    <p class="text-sm font-medium text-muted-foreground">{stat.label}</p>
                                    <p class="mt-3 text-2xl font-semibold tracking-[-0.03em] text-foreground">{stat.value}</p>
                                </div>
                                <span class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-primary/10 text-primary">
                                    <Icon className="h-5 w-5" />
                                </span>
                            </div>
                            <p class="mt-4 text-sm leading-6 text-muted-foreground">{stat.detail}</p>
                        </article>
                    );
                })
            }
        </section>

        <section class="grid gap-4 lg:grid-cols-3">
            {
                quickSignals.map((signal) => {
                    const Icon = signal.icon;

                    return (
                        <article class="rounded-[1.5rem] border border-border/70 bg-background/80 p-5 shadow-[0_10px_30px_rgba(18,38,31,0.04)]">
                            <div class="flex items-start gap-4">
                                <span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-accent/12 text-accent-foreground">
                                    <Icon className="h-5 w-5" />
                                </span>
                                <div>
                                    <p class="text-sm font-semibold uppercase tracking-[0.16em] text-muted-foreground">{signal.title}</p>
                                    <p class="mt-2 text-sm leading-6 text-foreground/86">{signal.text}</p>
                                </div>
                            </div>
                        </article>
                    );
                })
            }
        </section>

        <section id="dias" class="space-y-5">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
                <div>
                    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-primary">Rotacion de 4 dias</p>
                    <h2 class="mt-2 text-3xl font-semibold tracking-[-0.04em] text-foreground sm:text-4xl">
                        Sin dias fijos, solo secuencia
                    </h2>
                </div>
                <p class="max-w-2xl text-sm leading-6 text-muted-foreground">
                    Cada dia trabaja grupos musculares distintos. Hacelos en orden. Si faltas, retomas donde estabas.
                </p>
            </div>

            <TrainingDaysGrid client:load />
        </section>

        {
            exercises.length > 0 && (
                <section class="space-y-5">
                    <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
                        <div>
                            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-primary">Ejercicios</p>
                            <h2 class="mt-2 text-3xl font-semibold tracking-[-0.04em] text-foreground sm:text-4xl">
                                Todos los movimientos del plan
                            </h2>
                        </div>
                    </div>

                    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
                        {
                            exercises.map((exercise) => (
                                <article class="rounded-[1.75rem] border border-border/70 bg-card/80 p-5 shadow-[0_10px_30px_rgba(18,38,31,0.06)]">
                                    <img
                                        src={exercise.imageUrl}
                                        alt={exercise.nameEs}
                                        loading="lazy"
                                        onerror={`if (this.src !== '${exercise.imageFallbackUrl}') this.src='${exercise.imageFallbackUrl}'`}
                                        class="h-40 w-full rounded-[1.1rem] object-cover"
                                    />
                                    <h3 class="mt-4 text-xl font-semibold tracking-[-0.03em] text-foreground">{exercise.nameEs}</h3>
                                    <p class="mt-1 text-sm text-muted-foreground">{exercise.muscleGroup}</p>
                                    <div class="mt-4 flex flex-wrap gap-2 text-xs font-medium text-foreground/76">
                                        <span class="rounded-full bg-secondary px-3 py-1">{exercise.sets} series</span>
                                        <span class="rounded-full bg-secondary px-3 py-1">{exercise.reps} reps</span>
                                        <span class="rounded-full bg-secondary px-3 py-1">Descanso {exercise.restSeconds}s</span>
                                    </div>
                                    <p class="mt-4 text-sm leading-6 text-foreground/86">{exercise.description}</p>
                                    <div class="mt-4">
                                        <a
                                            href={exercise.videoUrl}
                                            target="_blank"
                                            rel="noreferrer"
                                            class="inline-flex items-center justify-center gap-2 rounded-full bg-primary px-3 py-2 text-sm font-semibold text-primary-foreground transition hover:bg-primary/90"
                                        >
                                            Ver video
                                        </a>
                                    </div>
                                </article>
                            ))
                        }
                    </div>
                </section>
            )
        }

        <section id="graficas" class="space-y-5">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
                <div>
                    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-primary">Graficas</p>
                    <h2 class="mt-2 text-3xl font-semibold tracking-[-0.04em] text-foreground sm:text-4xl">
                        Datos visuales del plan
                    </h2>
                </div>
                <p class="max-w-2xl text-sm leading-6 text-muted-foreground">
                    La progresion no se decide por intuicion. Se decide por tolerancia al esfuerzo, calidad tecnica y adherencia.
                </p>
            </div>
            <SessionCharts client:only="react" />
        </section>

        <section class="grid gap-5 lg:grid-cols-[0.95fr_1.05fr]">
            <div class="rounded-[2rem] border border-border/70 bg-card/80 p-5 shadow-[0_10px_30px_rgba(18,38,31,0.06)] sm:p-6">
                <div class="flex items-start gap-3">
                    <span class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-primary/10 text-primary">
                        <HeartPulse className="h-5 w-5" />
                    </span>
                    <div>
                        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-primary">Habitos criticos</p>
                        <h2 class="mt-1 text-3xl font-semibold tracking-[-0.04em] text-foreground">Lo que sostiene la progresion</h2>
                    </div>
                </div>
                <div class="mt-6 grid gap-4 sm:grid-cols-2">
                    {
                        habitGuides.map((habit) => {
                            const Icon = habitIcons[habit.title as keyof typeof habitIcons];

                            return (
                                <article class="rounded-[1.5rem] border border-border/70 bg-background/75 p-4">
                                    <div class="flex items-start gap-3">
                                        <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-accent/12 text-accent-foreground">
                                            <Icon className="h-4.5 w-4.5" />
                                        </span>
                                        <div>
                                            <h3 class="text-base font-semibold text-foreground">{habit.title}</h3>
                                            <p class="mt-2 text-sm leading-6 text-muted-foreground">{habit.description}</p>
                                        </div>
                                    </div>
                                </article>
                            );
                        })
                    }
                </div>
            </div>

            <div class="rounded-[2rem] border border-border/70 bg-card/80 p-2 shadow-[0_10px_30px_rgba(18,38,31,0.06)] sm:p-3">
                <ExerciseTabs client:load />
            </div>
        </section>

        <footer class="rounded-[2rem] border border-border/70 bg-background/90 px-6 py-5 text-sm leading-6 text-muted-foreground">
            Rotacion de 4 dias con ejercicios en maquinas guiadas. El siguiente paso es agregar logs de entrenamiento con RPE, energia, sueno y alertas de salud.
        </footer>
    </main>
    </AuthGuard>
</Layout>
