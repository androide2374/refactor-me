---
import { CalendarDays, ClipboardList, Clock3, Gauge, Heart, Ruler, Scale } from 'lucide-react';
import AppHeader from '../../components/AppHeader.astro';
import { partnerProfile } from '../../data/training-plan';
import Layout from '../../layouts/Layout.astro';

const partnerBmi = (partnerProfile.weightKg / (partnerProfile.heightCm / 100) ** 2).toFixed(1);

const profileStats = [
	{ label: 'Edad', value: `${partnerProfile.age} anos`, icon: CalendarDays },
	{ label: 'Peso', value: `${partnerProfile.weightKg} kg`, icon: Scale },
	{ label: 'Altura', value: `${partnerProfile.heightCm} cm`, icon: Ruler },
	{ label: 'IMC de referencia', value: partnerBmi, icon: Gauge }
];
---

<Layout title="OnFit Focus | Perfil pareja" description="Perfil de pareja creado y listo para cargar su plan cuando esten completos los datos de entrenamiento.">
	<main class="mx-auto flex min-h-screen max-w-5xl flex-col gap-10 px-4 py-6 sm:px-6 lg:px-8 lg:py-8">
		<AppHeader currentProfile="pareja" />

		<section class="rounded-[2rem] border border-border/70 bg-card/85 p-6 shadow-[0_24px_80px_rgba(18,38,31,0.14)] backdrop-blur sm:p-8">
			<p class="inline-flex items-center gap-2 rounded-full border border-amber-300/40 bg-amber-400/15 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-amber-200">
				<Clock3 className="h-3.5 w-3.5" />
				Plan pendiente
			</p>
			<h1 class="mt-4 text-4xl font-semibold tracking-[-0.04em] text-foreground sm:text-5xl">Perfil de tu pareja ya creado</h1>
			<p class="mt-4 max-w-3xl text-base leading-7 text-muted-foreground sm:text-lg">
				Este espacio queda listo para que agregues su plan cuando tengas todos los datos. Mientras tanto, mantenemos tu plan principal sin cambios.
			</p>
		</section>

		<section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
			{
				profileStats.map((stat) => {
					const Icon = stat.icon;

					return (
						<article class="rounded-[1.5rem] border border-border/70 bg-card/80 p-5 shadow-[0_10px_30px_rgba(18,38,31,0.06)]">
							<div class="flex items-center justify-between gap-3">
								<p class="text-sm font-medium text-muted-foreground">{stat.label}</p>
								<span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-primary/10 text-primary">
									<Icon className="h-5 w-5" />
								</span>
							</div>
							<p class="mt-3 text-2xl font-semibold tracking-[-0.03em] text-foreground">{stat.value}</p>
						</article>
					);
				})
			}
		</section>

		<section class="rounded-[2rem] border border-border/70 bg-card/80 p-6 shadow-[0_10px_30px_rgba(18,38,31,0.06)] sm:p-7">
			<div class="flex items-start gap-3">
				<span class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-primary/10 text-primary">
					<ClipboardList className="h-5 w-5" />
				</span>
				<div>
					<h2 class="text-2xl font-semibold tracking-[-0.03em] text-foreground">Datos que faltan para armar su plan</h2>
					<p class="mt-2 text-sm leading-6 text-muted-foreground">{partnerProfile.nextStep}</p>
				</div>
			</div>

			<ul class="mt-5 grid gap-3 text-sm leading-6 text-foreground/86 sm:grid-cols-2">
				<li class="rounded-[1.1rem] border border-border/70 bg-background/70 p-4">Nivel de energia promedio semanal (1-10).</li>
				<li class="rounded-[1.1rem] border border-border/70 bg-background/70 p-4">Horas de sueno en dias laborales y fines de semana.</li>
				<li class="rounded-[1.1rem] border border-border/70 bg-background/70 p-4">Experiencia previa en gimnasio y ejercicios tolerados.</li>
				<li class="rounded-[1.1rem] border border-border/70 bg-background/70 p-4">Molestias articulares, medicacion y disponibilidad semanal.</li>
			</ul>
		</section>

		<section class="rounded-[2rem] border border-border/70 bg-[#102019] p-6 text-white shadow-[0_10px_30px_rgba(18,38,31,0.08)] sm:p-7">
			<p class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/8 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-white/80">
				<Heart className="h-3.5 w-3.5" />
				Estado
			</p>
			<p class="mt-4 text-lg leading-7 text-white/85">
				Perfil creado con exito. Cuando quieras, en la proxima iteracion armamos su rutina completa y activamos la pantalla de ejercicios para este perfil.
			</p>
		</section>
	</main>
</Layout>
