---
import { ArrowLeft } from 'lucide-react';
import AppHeader from '../components/AppHeader.astro';
import AuthGuard from '../components/AuthGuard';
import ProgressionDashboard from '../components/ProgressionDashboard';
import Layout from '../layouts/Layout.astro';
---

<Layout title="Progreso | OnFit Focus" description="Seguimiento de peso corporal y cargas por ejercicio con graficos de progresion.">
    <AuthGuard client:load>
    <main class="mx-auto flex min-h-screen max-w-7xl flex-col gap-8 px-4 py-6 sm:px-6 lg:px-8 lg:py-8">
        <AppHeader />

        <section class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <p class="text-sm font-semibold uppercase tracking-[0.18em] text-primary">Progreso</p>
                <h1 class="mt-2 text-3xl font-semibold tracking-[-0.04em] text-foreground sm:text-4xl">
                    Evolucion de cargas y peso corporal
                </h1>
            </div>
            <a
                href="/"
                class="inline-flex items-center gap-2 self-start rounded-full border border-border bg-background px-4 py-2 text-sm font-semibold text-foreground transition hover:border-primary/30"
            >
                <ArrowLeft className="h-4 w-4" />
                Volver al inicio
            </a>
        </section>

        <div id="progreso-charts">
            <ProgressionDashboard client:only="react" />
        </div>
    </main>
    </AuthGuard>
</Layout>
